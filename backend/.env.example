# Application
APP_NAME=AI Video Platform
APP_VERSION=1.0.0
DEBUG=true
ENV=development

# Server
HOST=0.0.0.0
PORT=8000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Database
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/ai_video_platform?charset=utf8mb4

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10

# OSS (Qiniu)
QINIU_ACCESS_KEY=your-qiniu-access-key
QINIU_SECRET_KEY=your-qiniu-secret-key
QINIU_BUCKET=ai-video-platform
QINIU_CDN_DOMAIN=https://cdn.example.com

# Aliyun SMS
ALIYUN_ACCESS_KEY=your-aliyun-access-key
ALIYUN_SECRET_KEY=your-aliyun-secret-key
ALIYUN_SMS_SIGN_NAME=AI视频平台
ALIYUN_SMS_TEMPLATE_CODE=SMS_xxxxxxx

# WeChat Pay
WECHAT_APP_ID=your-wechat-app-id
WECHAT_MCH_ID=your-wechat-mch-id
WECHAT_API_KEY=your-wechat-api-key
WECHAT_CERT_PATH=/path/to/apiclient_cert.pem
WECHAT_KEY_PATH=/path/to/apiclient_key.pem

# AI Service
AI_SERVICE_URL=https://api.example.com
AI_SERVICE_API_KEY=your-ai-service-api-key