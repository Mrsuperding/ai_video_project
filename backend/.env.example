# 应用基础配置
APP_NAME=AI数字人视频定制平台
APP_VERSION=1.0.0
DEBUG=false

# 服务地址
HOST=0.0.0.0
PORT=8000

# 数据库配置
DATABASE_URL=mysql+pymysql://root:your_password@localhost:3306/ai_video_platform?charset=utf8mb4

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT 配置（生产环境请使用强密钥）
JWT_SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 阿里云 OSS 配置（推荐）
ALIYUN_ACCESS_KEY=your_aliyun_access_key
ALIYUN_SECRET_KEY=your_aliyun_secret_key
ALIYUN_BUCKET=your_bucket_name
ALIYUN_REGION=oss-cn-hangzhou
ALIYUN_CDN_DOMAIN=

# 七牛云 OSS（备选，不推荐）
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_BUCKET=
QINIU_CDN_DOMAIN=

# 短信配置（阿里云）
ALIYUN_SMS_ACCESS_KEY=
ALIYUN_SMS_SECRET_KEY=
ALIYUN_SMS_SIGN_NAME=AI数字人平台
ALIYUN_SMS_TEMPLATE_CODE=

# 微信支付配置
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_KEY=
WECHAT_CERT_PATH=
WECHAT_KEY_PATH=

# AI 服务配置
AI_SERVICE_URL=
AI_SERVICE_API_KEY=

# 速率限制配置
RATE_LIMIT_PER_MINUTE=60

# CORS 配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
